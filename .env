# ── HuggingFace ────────────────────────────────────────────────────────────────
HF_TOKEN=hf_your_token_here

# ── Grafana ────────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=SecurePass123!

# ── Model ──────────────────────────────────────────────────────────────────────
# Initial model on first boot. Can be changed via UI later.
MODEL_PATH=Qwen/Qwen2.5-7B-Instruct

# ── vLLM Hardware Profile (A100 defaults) ──────────────────────────────────────
GPU_MEMORY_UTILIZATION=0.90
MAX_MODEL_LEN=8192
TENSOR_PARALLEL_SIZE=1
DTYPE=bfloat16
GPU_COUNT=1

# ── Stack internals ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
VLLM_CONTAINER_NAME=vllm-server
COMPOSE_PROJECT_NAME=vllm-stack
