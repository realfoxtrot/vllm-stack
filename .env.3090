# ── vLLM Hardware Profile (Dual RTX 3090 overrides) ───────────────────────────
# 3090 has no BF16 — must use float16
DTYPE=float16

# Tensor parallelism across 2x 3090 (48GB total VRAM)
TENSOR_PARALLEL_SIZE=2
GPU_COUNT=2

# Conservative memory — 3090 consumer VRAM is less stable at 0.90
GPU_MEMORY_UTILIZATION=0.85

# Reduce context window to fit in 24GB per GPU with TP=2
MAX_MODEL_LEN=4096

# Recommended models for this config:
# - Qwen/Qwen2.5-14B-Instruct       (fp16, ~28GB total, fits with TP=2)
# - TheBloke/Mixtral-8x7B-Instruct-v0.1-AWQ  (AWQ quant, ~24GB)
# - Qwen/Qwen2.5-7B-Instruct        (comfortable, leaves headroom)
MODEL_PATH=Qwen/Qwen2.5-14B-Instruct
