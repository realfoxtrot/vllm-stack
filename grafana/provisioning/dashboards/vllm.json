{
  "id": null,
  "uid": "vllm-stack-001",
  "title": "vLLM & GPU Metrics",
  "schemaVersion": 38,
  "version": 1,
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "GPU KV Cache Usage (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "vllm:gpu_cache_usage_percent * 100",
          "legendFormat": "KV Cache %"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Token Throughput (tokens/sec)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(vllm:num_tokens_total[1m])",
          "legendFormat": "Tokens/s"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Queue Depth (Waiting Requests)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "vllm:num_requests_waiting",
          "legendFormat": "Waiting"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "GPU Temperature (°C)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_TEMP",
          "legendFormat": "GPU {{gpu}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "GPU Memory Used (MiB)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED",
          "legendFormat": "GPU {{gpu}} Used MiB"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Time To First Token (p95, ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(vllm:time_to_first_token_seconds_bucket[5m])) * 1000",
          "legendFormat": "TTFT p95"
        }
      ]
    }
  ]
}
